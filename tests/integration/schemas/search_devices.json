            "type": {
              "enum": [
                "lua",
                "virtual_ucm",
                "hardware_ucm",
                "standalone",
                "gateway",
                "link_master_ucm",
                "link_slave_ucm",
                "embedded_ucm",
                "native",
                "child"
              ],
              "type": "string"
            }
          },
          "required": [
            "id",
            "blueprint_id",
            "name",
            "site_id",
            "type",
            "authorized_role",
            "blueprint_summary",
            "connectivity_status",
            "active_alerts_total"
          ],
          "type": "object"
        },
        "type": "array"
      }
    },
