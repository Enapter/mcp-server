  "name": "search_devices",
  "outputSchema": {
    "properties": {
      "result": {
        "items": {
          "description": "Represents a device.\n\nAn individual unit that can be monitored and controlled.\n\nThe `authorized_role` field indicates the authenticated user's access\nlevel for this device. For property values, telemetry data, and command\nexecution, a user can read the value (or execute the command) only if\ntheir `authorized_role` is at or after the declaration's `access_level`.",
          "properties": {
            "active_alerts": {
              "anyOf": [
                {
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "active_alerts_total": {
              "type": "integer"
            },
            "authorized_role": {
              "description": "Roles in priority order: readonly < user < owner < installer < vendor < system.",
              "enum": [
                "readonly",
                "user",
                "owner",
                "installer",
                "vendor",
                "system"
              ],
              "type": "string"
            },
            "blueprint_id": {
              "type": "string"
            },
            "blueprint_summary": {
              "description": "A summary of a blueprint's key attributes.\n\nA blueprint is a specification that defines the integration between Enapter\nand a device. It outlines the available telemetry attributes, commands,\nproperties, and alerts that the device supports. Every device has a\nblueprint assigned to it.",
              "properties": {
                "alerts_total": {
                  "type": "integer"
                },
                "commands_total": {
                  "type": "integer"
                },
                "description": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "properties_total": {
                  "type": "integer"
                },
                "telemetry_attributes_total": {
                  "type": "integer"
                },
                "vendor": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              },
              "required": [
                "description",
                "vendor",
                "commands_total",
                "properties_total",
                "telemetry_attributes_total",
                "alerts_total"
              ],
              "type": "object"
            },
            "connectivity_status": {
              "enum": [
                "unknown",
                "online",
                "offline"
              ],
              "type": "string"
            },
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "properties": {
              "anyOf": [
                {
                  "additionalProperties": true,
                  "type": "object"
                },
